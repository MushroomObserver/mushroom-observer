<%
heading = :show_name_general_description.l
desc = @name&.description
link1 = if desc
          icon_link_to(*Tab::Name::ShowDescription.new(name: @name).to_a)
        end
link2 = if desc && permission?(desc)
          icon_link_to(*Tab::Name::EditDescription.new(name: @name).to_a)
        end
heading_links = @user ? [link1, link2].reject(&:nil?).safe_join(" | ") : ""
%>

<%= render(Components::Panel.new(
      panel_id: "name_general_description"
    )) do |panel| %>
  <%= panel.with_heading { heading } %>
  <%= panel.with_heading_links { heading_links } if @user %>
  <%= panel.with_body { @best_description.tpl } %>
<% end %>
