<%# Nomenclature partial; used by:
    show_name, show_past_name, and add_comment (via _object) %>
<%
unlocked = in_admin_mode? || !name.locked
approve = if unlocked && name.deprecated && name.correct_spelling_id.nil?
            icon_link_to(*Tab::Name::Approve.new(name: name).to_a)
          end
deprecate = if unlocked && !name.deprecated
              icon_link_to(*Tab::Name::Deprecate.new(name: name).to_a)
            end
synonyms = if unlocked
             icon_link_to(*Tab::Name::EditSynonym.new(name: name).to_a)
           end
edit = icon_link_to(*Tab::Name::Edit.new(name: name).to_a)
heading_links = edit
synonym_links = [approve, deprecate].reject(&:nil?).safe_join(" | ")
%>

<%= render(Components::Panel.new(
      panel_class: "name-section",
      panel_id: "nomenclature"
    )) do |panel| %>
  <%= panel.with_heading { :show_name_nomenclature.l } %>
  <%= panel.with_heading_links { heading_links } if @user %>
  <%= panel.with_body do %>
    <% concat(tag.div(class: "row") do

      concat(tag.div(class: "col-sm-6 name-section") do
        [
          tag.p do
            "#{:RANK.l}: #{name.rank ? rank_as_string(name.rank) : :unknown.l}"
          end,
          tag.p do
            concat("#{:STATUS.l}: ")
            concat(name.status)
            concat(" (#{:MISSPELLED.l})") if name.is_misspelling?
            concat(
              [tag.span(class: "text-nowrap ml-3") { synonym_links }].safe_join
            ) if synonym_links
          end,
          tag.p do
            concat("#{:NAME.l}: ")
            concat(h(name.user_real_text_name(@user)))
            concat(
              [tag.span(class: "text-nowrap ml-3") { synonyms }].safe_join
            ) if synonyms
            concat(tag.p(["#{:AUTHORITY.l}: ", name.author.to_s.t].safe_join))
            concat(tag.p(["#{:CITATION.l}: ", name.citation.to_s.tl].safe_join))
          end
        ].safe_join
      end)

      concat(tag.div(class: "col-sm-6 name-section") do
        if name.icn_id?
          [
            tag.p do
              [link_to(*Tab::Name::IndexFungorumRecord.new(name: name).to_a),
              "Index Fungorum"].safe_join(" ")
            end,
            tag.p do
              [link_to(*Tab::Name::MycobankRecord.new(name: name).to_a),
              "MycoBank"].safe_join(" ")
            end,
            tag.p do
              if name.at_or_below_species?
                link_to(*Tab::Name::FungorumGsdSynonymy.new(name: name).to_a)
              elsif ["Genus", "Family"].include?(name.rank)
                link_to(*Tab::Name::FungorumSfSynonymy.new(name: name).to_a)
              end
            end
          ].safe_join
        elsif name.registrable?
          [
            tag.p do
              ["#{:ICN_ID.l}:",
              tag.em(:show_name_icn_id_missing.l)].safe_join(" ")
            end,
            tag.p(link_to(*Tab::Name::IndexFungorumSearchPage.new.to_a)),
            tag.p(link_to(
              *Tab::Name::IndexFungorumNameSearch.new(name: name).to_a
            )),
            tag.p(link_to(*Tab::Name::MycobankSearch.new(name: name).to_a))
          ].safe_join
        elsif name.searchable_in_registry?
          [
            tag.p(link_to(*Tab::Name::IndexFungorumSearchPage.new.to_a)),
            tag.p(link_to(
              *Tab::Name::IndexFungorumNameSearch.new(name: name).to_a
            )),
            tag.p(link_to(*Tab::Name::MycobankBasicSearch.new.to_a))
          ].safe_join
        end
      end)

    end) %>

    <% if name.is_misspelling? %>
      <% concat(tag.p do
        concat("#{:show_name_misspelling_correct.l}: ")
        if name.correct_spelling
          concat(link_to(name.correct_spelling.user_display_name(@user).t,
                        name_path(name.correct_spelling_id)))
        else
          # This can apparently happen for past_names.
          concat(name.correct_spelling_id)
        end
      end) %>
    <% end %>

    <% if synonyms %>
      <%
      approved_synonyms, deprecated_synonyms = name.sort_synonyms
      misspellings = deprecated_synonyms.select(&:correct_spelling_id)
      deprecated_synonyms.reject!(&:correct_spelling_id)

      # Iterate over an array, these are very similar
      [
        { label: name.deprecated ?
            :show_name_preferred_synonyms.l : :show_name_synonyms.l,
          names: approved_synonyms },
        { label: :show_name_deprecated_synonyms.l,
          names: deprecated_synonyms },
        { label: :show_name_misspelled_synonyms.l,
          names: misspellings }
      ].map do |possible_synonyms|
        if possible_synonyms[:names].try(&:any?)
          concat(tag.p do
            concat("#{possible_synonyms[:label]}: ")
            concat(
              possible_synonyms[:names].map do |n|
                link_to(n.user_display_name(@user).t, name_path(n.id))
              end.safe_join(", ")
            )
          end)
        end
      end
      %>
    <% end %>
  <% end %>
<% end %>
