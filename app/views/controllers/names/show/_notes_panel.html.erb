<%
heading = :show_name_notes.l
link = icon_link_to(*Tab::Name::Edit.new(name: @name).to_a)
heading_links = @user ? link.html_safe : ""
%>

<%= render(Components::Panel.new(
      panel_id: "name_notes"
    )) do |panel| %>
  <%= panel.with_heading { heading } %>
  <%= panel.with_heading_links { heading_links } if @user %>
  <%= panel.with_body { @name.notes.tpl } %>
<% end %>
