<%
  add_page_title("#{:field_slip_new.t}: #{@field_slip.code}")
  add_context_nav([field_slips_index_tab])
  container_class(:full)
%>

<%= render("form", field_slip: @field_slip, species_list: @species_list) %>
<% if @field_slip_project_gaps&.any? %>
  <%= render(Components::OccurrenceResolveModal.new(
               gaps: @field_slip_project_gaps,
               primary: @field_slip_occurrence.primary_observation,
               user: @user,
               occurrence: @field_slip_occurrence
             )) %>
<% end %>
