<%
container_class(:full)
add_project_banner(@project) if @project
add_page_title(checklist_show_title(user: @show_user, list: @species_list))
add_context_nav(checklist_show_tabs(user: @show_user, list: @species_list))
%>

<% if @project&.is_admin?(@user) %>
  <%= render(partial: "projects/target_names/widget",
             locals: { project: @project }) %>
<% end %>

<div class="my-4">
  <%= :checklist_summary.t(species: @data.num_species,
                           genera: @data.num_genera,
                           names: @data.num_taxa) %>
</div>

<% if @location %>
  <h4>
    <%= :checklist_for.t %>
    <%= location_link(nil, @location) %>
  </h4>
<% end %>

<%= render(partial: "checklists/checklist_panel",
           locals: { data: @data, user: @user, project: @project,
                     show_user: @show_user, location: @location,
                     species_list: @species_list }) %>

<div>
  <%= tag.p(:checklist_any_deprecated.l) if @data.any_deprecated? %>
  <%= tag.p(:checklist_duplicate_synonyms.l) if @data.duplicate_synonyms.present? %>
</div>
