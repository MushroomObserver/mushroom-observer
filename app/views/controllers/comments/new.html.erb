<%
container_class(:full)
add_page_title(:comment_add_title.t(name: @target.unique_format_name))
add_context_nav(Tab::Comment::FormNew.new(target: @target))
%>

<div class="row">
  <div class="col-xs-12 col-sm-8">
    <!--[form:comment]-->
    <%= render(Views::Controllers::Comments::Form.new(@comment, local: true)) %>
    <!--[eoform:comment]-->
    <%= render(partial: "comments/object", object: @target) %>
  </div>

  <% if @target.is_a?(Observation) %>
    <div class="col-xs-12 col-sm-4">
      <%= render(partial: "observations/show/images",
                 locals: { obs: @target, thumb_size_control: false }) %>
    </div>
  <% end %>
</div>
<!--.row-->
