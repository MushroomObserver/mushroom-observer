<%# locals: (comment: nil, controls: @user, show_name: false) %>
<%
target = comment.target # comment is passed in as `object` in some cases
user = comment.user

target_name_link = link_to(target.user_unique_format_name(@user).t,
                           target.show_link_args) \
                   rescue :comment_list_deleted.t
target_type = tag.span(target.class.name.to_sym.t, class: "small") \
                       rescue :runtime_object_deleted
%>

<%# Note: we intentionally do NOT wire data-controller="section-update"
    here. The submitter's comment modal is closed directly by the
    turbo_stream response from CommentsController. If this were also
    attached here, an Action Cable broadcast arriving in a second
    window — or triggered by a different user entirely — would close
    any modal the viewing user happens to have open, potentially
    losing in-progress form content. %>
<%=
tag.div(
  class: "list-group-item comment",
  id: dom_id(comment)
) do
  concat(tag.div(class: "row") do
    [
      tag.div(class: "col-xs-12 col-sm-9 col-lg-10") do
        if local_assigns[:show_name] && show_name
          concat(tag.h4(class: "mt-0") do
            [target_name_link, target_type].safe_join(" ")
          end)
        end
        concat(tag.div(comment.summary.tl,
                       class: "comment-summary font-weight-bold"))
        concat(tag.div(class: "comment-info") do
          concat(tag.span(class: "comment-author text-nowrap") do
            ["#{:BY.t}: ",
             if controls
               render(Components::UserLink.new(user: user))
             else
               user.unique_text_name
             end,
             " "].safe_join
          end)
          concat(tag.span(class: "text-nowrap",
                          data: { user_specific: comment.user.id }) do
            # Two render contexts, two permission strategies:
            #
            # - Normal request — `@user` is the current viewer.
            #   `InlineModLinks` gates on
            #   `target.user == @user || in_admin_mode?` and the
            #   links don't appear in the HTML for non-authors
            #   at all (defense in depth even with the CSS
            #   hidden-by-default).
            # - Action Cable broadcast (from the model's
            #   `after_create_commit` / `after_update_commit`
            #   callbacks) — `@user` is nil. Fall back to
            #   `comment.user` so the gate passes; the markup
            #   gets broadcast unconditionally. The surrounding
            #   span's `data-user-specific` attribute teams up
            #   with the site-wide `[data-user-specific]:not(…)`
            #   CSS rule (`_user_specific_css.html.erb`) to hide
            #   for everyone except the comment's author on the
            #   receiving end. Admin mode bypasses the CSS so
            #   admins still see them.
            render(Components::InlineModLinks.new(
                     target: comment, user: @user || comment.user,
                     indent: false
                   ))
          end) if controls
          concat(tag.div(comment.created_at.web_time,
                         class: "float-sm-right text-nowrap small"))
        end)
        unless comment.comment.blank?
          concat(tag.div("", class: "clearfix"))
          concat(tag.div(comment.comment.tpl, class: "p-2 comment-body"))
        end
      end,
      tag.div(class: "d-none d-sm-block col-sm-3 col-lg-2 text-center") do
        if user.image_id
          tag.div(class: "user-image-sizer") do
            image_tag(Image.url(:thumbnail, user.image_id),
                      class: "img-fluid",
                      data: { role: "link", url: user_path(user.id) })
          end
        end
      end
    ].safe_join
  end)
  concat(tag.div("", class: "clearfix")) if user.image_id
end %>
