<%
container_class(:wide)
add_show_title(@article)
add_edit_icons(@article, @user)
%>

<%= content_padded do %>
  <%= :BY.t %> <%= render(Components::UserLink.new(user: @article.user)) %>,
  <%= tag.small(@article.created_at.display_time) %>
<% end %>

<%= render(Components::Panel.new(panel_class: "mt-3")) do |panel| %>
  <%= panel.with_body { @article.body.tpl } %>
<% end %>

<%= render(Components::VersionsFooter.new(user: @user, obj: @article)) %>
