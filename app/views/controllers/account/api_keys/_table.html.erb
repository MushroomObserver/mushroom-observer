<%# Double-duty UI: each row has an inline "edit notes" panel that
    un-collapses on the edit-icon click; the bottom panel below the
    table is the "+ Add Key" inline create form. JS-driven via
    Bootstrap collapse.js. The standalone `/account/api_keys/new`
    route is the no-JS fallback. %>

<%= render(Components::Table.new(
             api_keys_sorted(@user),
             id: "account_api_keys_table",
             class: "table-striped")) do |t| %>
  <% t.column(:account_api_keys_active_column_label.t) do |key| %>
    <%= api_key_id_verified_or_activate(key) %>
  <% end %>
  <% t.column(:CREATED.t) { |key| key.created_at.web_date } %>
  <% t.column(:account_api_keys_last_used_column_label.t) do |key| %>
    <%= key.last_used ? key.last_used.web_date : "--" %>
  <% end %>
  <% t.column(:account_api_keys_num_uses_column_label.t) do |key| %>
    <%= key.num_uses.positive? ? key.num_uses : "--" %>
  <% end %>
  <% t.column(:API_KEY.t) { |key| h(key.key) } %>
  <% t.column(:NOTES.t) { |key| api_keys_notes_section(key) } %>
  <% t.column("") { |key| api_keys_remove_button(key) } %>
<% end %>

<%= api_keys_new_form_panel %>
