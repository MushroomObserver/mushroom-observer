<%
add_show_title(@location)
if @user
  add_edit_icons(@location, @user)
  add_interest_icons(@user, @location)
  add_pager_for(@location)
end
container_class(:full)
column_classes(:seven_five)
%>

<% if @location.hidden %>
  <%= tag.p(:show_location_hidden.t) %>
<% end %>

<%= tag.div(class: "row") do %>
  <%= tag.div(class: yield(:left_columns)) do %>
    <%= tag.div(class: "mb-5") { make_map(objects: [@location]) } %>
    <%= render(partial: "locations/show/general_description_panel") %>
    <%= render(Views::Controllers::Comments::CommentsForObject.new(
                 object: @location, comments: @comments, user: @user,
                 editable: @user.present?, limit: 2
               )) %>
  <% end %>

  <%= tag.div(class: yield(:right_columns)) do %>
    <%= render(partial: "locations/show/coordinates") %>
    <%= render(partial: "locations/show/notes") %>
    <%= render(Views::Controllers::Locations::Show::AltDescriptionsPanel.new(
                 user: @user, object: @location, projects: @projects
               )) %>
    <%= render(partial: "locations/show/footer") %>
  <% end %>
<% end %>
<!--.row-->

<%= tag.div(class: "mt-3") do %>
  <%= render(Components::ObjectFooter.new(user: @user, obj: @location, versions: @versions)) %>
<% end %>
