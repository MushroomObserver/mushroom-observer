<% if @description&.notes? %>

  <%
  heading = :show_name_general_description.l
  link1 = render(Components::IconLink.new(
    tab: Tab::Location::ShowDescription.new(location: @location)
  ))
  link2 = render(Components::IconLink.new(
    tab: Tab::Location::EditDescription.new(location: @location)
  ))
  heading_links = @user ? [link1, link2].reject(&:nil?).safe_join(" | ") : ""
  %>

  <%= render(Components::Panel.new(
        panel_id: "location_general_description"
      )) do |panel| %>
    <%= panel.with_heading { heading } %>
    <%= panel.with_heading_links { heading_links } if @user %>
    <%= panel.with_body { @description.notes.tpl } %>
  <% end %>

<% end %>

