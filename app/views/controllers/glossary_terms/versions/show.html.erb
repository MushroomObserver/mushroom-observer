<%
add_page_title(:show_past_glossary_term_title.t(
  num: @glossary_term.version,
  name: @glossary_term.name
))

add_context_nav(Tab::GlossaryTerm::VersionActions.new(term: @glossary_term))
container_class(:wide)
column_classes(:six)
%>

<%= tag.div(class: "row") do %>
  <%= tag.div(class: yield(:left_columns)) do %>
    <%= render(partial: "glossary_terms/glossary_term",
               object: @glossary_term,
               locals: { synonyms: false }) %>
  <% end %>

  <%= tag.div(class: yield(:right_columns)) do %>
    <%= render(Views::Controllers::Versions::Table.new(
          obj: @glossary_term, versions: @versions
        )) %>
  <% end %>
<% end %>
<!--.row-->

<%= render(Components::VersionsFooter.new(user: @user, obj: @glossary_term, versions: @versions)) %>
