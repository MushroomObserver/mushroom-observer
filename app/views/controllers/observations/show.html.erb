<%
add_show_title(@observation, user: @user)
add_owner_naming(owner_naming_line(name: @observation.name,
                                   owner_name: @owner_name, user: @user))
if @user
  add_pager_for(@observation)
  add_interest_icons(@user, @observation)
  add_edit_icons(@observation, @user)
end

container_class(:double)
column_classes(:eight_four)

show_map   = @user ? @user.thumbnail_maps : !session[:hide_thumbnail_maps]
show_lists = @user # && @observation.species_lists.any?

obs_locals = { obs: @observation, consensus: @consensus, user: @user }
%>

<%= render(Views::Controllers::Observations::ImportedSourceBanner.new(observation: @observation)) %>

<%= tag.div(class: "row") do %>
  <%= tag.div(class: yield(:left_columns)) do %>
    <%= render(Components::Carousel.new(
          object: @observation,
          images: @images,
          carousel_id: "observation_images",
          user: @user,
          title: :IMAGES.t,
          links: (permission?(@observation) ?
                  icon_link_to(*Tab::Observation::ReuseImages.new(
                    observation: @observation
                  ).to_a) : "")
        )) %>
  <% end %>

  <%= tag.div(class: yield(:right_columns)) do %>
    <%= render(
          Views::Controllers::Observations::Show::ObservationDetailsPanel.new(
            obs: @observation, consensus: @consensus, user: @user,
            sites: @other_sites&.to_a,
            siblings: @sibling_observations || []
          )
        ) %>
    <% if @user %>
      <%= render(
            Views::Controllers::Observations::Show::NameInfoPanel.new(
              obs: @observation, user: @user
            )
          ) %>

      <% if show_lists %>
        <%= render(
              Views::Controllers::Observations::Show::SpeciesListsPanel.new(
                obs: @observation, user: @user
              )
            ) %>
      <% end %>

      <%= render(
            Views::Controllers::Observations::Show::AssociatedObservationsPanel.new(
              obs: @observation, occurrence: @occurrence,
              siblings: @sibling_observations || [], user: @user
            )
          ) %>
    <% end %>
  <% end %>
<% end %>
<!--.row-->

<%= tag.div(class: "row") do %>
  <%= tag.div(class: yield(:left_columns)) do %>
    <% if @user %>
      <%= render(partial: "observations/show/namings", locals: obs_locals) %>
    <% end %>

    <%= render(partial: "comments/comments_for_object",
               locals: { object: @observation, comments: @comments,
                         controls: @user, limit: nil }) %>

    <%# External-source credit is rendered in the banner above. %>
    <% if @observation.source_noteworthy? && !@observation.external_source %>
      <%= @observation.source_credit.tpl %>
    <% end %>
  <% end %>

  <% if @user %>
    <%= tag.div(class: yield(:right_columns)) do %>
      <% if show_map %>
        <%= render(
              Views::Controllers::Observations::Show::ThumbnailMapPanel.new(
                obs: @observation, user: @user
              )
            ) %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
<!--.row-->

<% if @user %>
  <%= render(Components::ObjectFooter.new(user: @user, obj: @observation)) %>
<% end %>

