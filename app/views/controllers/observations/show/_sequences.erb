<%# locals: (obs: nil, consensus: nil, user: nil, sites: nil, has_sibling_records: false) %>

<%
sequences = obs.sequences
can_edit  = in_admin_mode? || obs.can_edit?(user)
%>

<%=
tag.div(
  id: "observation_sequences", class: "obs-sequence",
  data: { controller: "section-update", section_update_user_value: user.id }
) do

  concat(tag.div do
    no_seq_label = has_sibling_records ?
                     "#{:show_observation_dna_sequences.l}: " :
                     "#{:show_observation_no_sequences.l} "
    concat(sequences.any? ? "#{:show_observation_dna_sequences.l}: " :
                            no_seq_label)
    concat(
      ["[",
       modal_link_to("sequence",
                     *Tab::Sequence::New.new(observation: obs).to_a),
       "]"].safe_join
    ) if user
  end) if user || sequences.any?

  concat(tag.ul(class:"tight-list") do
    sequences.each do |sequence|
      concat(tag.li(id: "sequence_#{sequence.id}") do
        concat(link_to(*Tab::Sequence::Show.new(
          sequence: sequence, observation: obs
        ).to_a))

        links = []
        if sequence.deposit?
          links << link_to(*Tab::Sequence::Archive.new(
            sequence: sequence
          ).to_a)
        end
        if in_admin_mode? || sequence.can_edit?(user)
          links << modal_link_to(
            "sequence_#{sequence.id}",
            *Tab::Sequence::Edit.new(
              sequence: sequence, observation: obs
            ).to_a
          )
          links << destroy_button(
            name: :destroy_object.t(type: :sequence),
            target: sequence_path(id: sequence.id, back: observation_path(obs)),
            icon: :remove, btn: nil,
            class: "destroy_sequence_link_#{sequence.id}"
          )
        end
        concat(" [#{links.safe_join(' | ')}]".html_safe) if links.any?
      end)
    end
  end) if sequences.any?

end %>
