<%# locals: (user: nil, obs: nil, consensus: nil) %>

<%
merged = consensus.merged_namings
any_names = merged.any?
%>

<%=
tag.div(
  id: "namings_table_rows",
  class: "list-group list-group-flush"
) do
  if any_names
    merged.each do |merged_naming|
      concat(
        render(partial: "observations/show/namings/row",
               locals: {
                 **naming_row_content(user, consensus, merged_naming)
               })
      )
    end
  else
    tag.div(:show_namings_no_names_yet.t, class: "list-group-item")
  end
end
%>
