<%# locals: (identifier: "", obs: nil, user: nil, consensus: nil, sites: nil, siblings: []) %>

<%#
Turbo live-update wrapper for the obs-show sub-panels.

Triggered by the CollectionNumbers / HerbariumRecords /
Sequences / ExternalLinks controllers after create / update /
destroy: replace the relevant sub-panel + update the page flash.

The sub-panel renderers are now Phlex views
(`Views::Controllers::Observations::Show::*Panel`) — this
ERB stays as-is for turbo_stream composition, dispatching to
the right Phlex class by identifier.
%>

<%
section_panels = {
  "collection_numbers" => Views::Controllers::Observations::Show::CollectionNumbersPanel,
  "herbarium_records" => Views::Controllers::Observations::Show::HerbariumRecordsPanel,
  "sequences" => Views::Controllers::Observations::Show::SequencesPanel,
  "external_links" => Views::Controllers::Observations::Show::ExternalLinksPanel,
  "namings" => Views::Controllers::Observations::Show::Namings
}.freeze

panel_class = section_panels[identifier]
panel_props = { obs: obs, user: user }
if identifier == "external_links"
  # Convert AR::Relation to Array for the Phlex prop's
  # `_Array(::ExternalSite)` type check (Relation isn't an Array).
  panel_props.merge!(sites: sites&.to_a, siblings: siblings || [])
elsif identifier == "namings"
  panel_props[:consensus] = consensus
else
  panel_props[:has_sibling_records] = false
end
%>

<%= turbo_stream.replace("observation_#{identifier}") do
  render(panel_class.new(**panel_props)) if panel_class
end %>

<%= turbo_stream.update("page_flash") do
  flash_notices_html
end %>
