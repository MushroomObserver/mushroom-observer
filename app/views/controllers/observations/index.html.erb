<%
add_project_banner(@project) if @project
project_observation_buttons(@project, @query)
container_class(:full)
add_index_title(@query) # note default above is non-nil
if @objects.any?
  add_context_nav(Tab::Observation::IndexActions.new(
                    query: @query, where: params[:where],
                    q_param: q_param(@query), controller: controller
                  ))
end
add_sorter(@query, controller.index_sort_options)
add_pagination(@pagination_data)

flash_error(@error) if @error && @objects.empty?
%>

<% if @objects.empty? && @name_suggestions.any? %>
  <%= render(
        Views::Controllers::Observations::Show::NameSuggestionsAlert.new(
          names: @name_suggestions
        )
      ) %>
<% end %>

<%= paginated_results do %>
  <%= render(Components::MatrixTable.new(
    objects: @objects,
    user: @user,
    cached: true,
    project: @project
  )) %>
<% end %>
