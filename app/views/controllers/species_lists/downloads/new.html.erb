<%
add_page_title(:species_list_download_title.t)

add_context_nav(species_list_download_tabs(list: @list))

query_param = q_param(@query)
%>

<%= render(Views::Controllers::SpeciesLists::Downloads::Form.new(query_param: query_param)) %>

<%= render(Views::Controllers::SpeciesLists::Downloads::ReportForm.new(
             list: @list,
             query_param: query_param,
             selected: @type
           )) %>

<%= render(Views::Controllers::Observations::Downloads::Form.new(
      query_param: query_param,
      format: @format,
      encoding: @encoding
    )) %>
