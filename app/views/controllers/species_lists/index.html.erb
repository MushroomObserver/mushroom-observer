<%
add_project_banner(@project) if @project
add_index_title(@query)
add_sorter(@query, species_lists_index_sorts(query: @query))
add_pagination(@pagination_data)
container_class(:wide)

flash_error(@error) if @error && @objects.empty?
%>

<%= paginated_results do %>
  <% if @objects.any? %>
    <%= tag.div(class: "list-group") do %>
      <% @objects.each do |species_list| %>
        <%= render(Views::Controllers::SpeciesLists::Listing.new(
                     species_list: species_list,
                     project: @project
                   )) %>
      <% end %>
    <% end %>
  <% end %>
<% end %>

