<%
container_class(:wide)
add_edit_title(@sequence)
add_context_nav(Tab::Sequence::Form.new(back_object: @back_object))

obs = @sequence.observation
%>

<div class="row">
  <div class="col-xs-12 col-sm-7">
    <%= render(partial: "sequences/observation_title",
               locals: { observation: obs }) %>
    <%= render(Views::Controllers::Sequences::Form.new(@sequence,
                                                       back: @back)) %>

    <div class="small">
      <span class="font-weight-bold"><%= :CREATED_BY.t %>:</span>
      <%= render(Components::UserLink.new(user: @sequence.user)) %>
    </div>

    <%= render(Components::VersionsFooter.new(user: @user, obj: @sequence)) %>
  </div>

  <div class="col-xs-12 col-sm-5">
    <ul class="row list-unstyled">
      <%= render(::Components::MatrixBox.new(
                   user: @user,
                   object: obs.rss_log || obs,
                   columns: "col-xs-12")) %>
    </ul>
  </div>
</div>
<!--.row-->
